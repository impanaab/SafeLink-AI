{
  "manifest_version": 3,
  "name": "SafeLink AI Login Detector",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
